*{box-sizing:border-box}
:root{
  --pink:#ff55cd;--purple:#9b43ff;--cyan:#00ead1;--line:#3d2454;
  --cream:#fbf6ef;--sand:#f0dfcf;--taupe:#a8795e;--brown:#8b5d45;--petrol:#174f61;--ink:#182026
}
html.largeText{font-size:18px}
body{margin:0;background:#02040d;color:white;font-family:Segoe UI,Arial,sans-serif}
body.contrast{filter:contrast(1.18) brightness(1.06)}
button,a{font:inherit;color:inherit}
button{cursor:pointer}

/* -------- V2 professionnelle en premier -------- */
.proSite{min-height:100vh;background:linear-gradient(135deg,#fffaf4,#f3e6d8 70%,#edf5f3);color:var(--ink)}
.proNav{
  position:sticky;top:0;z-index:70;min-height:78px;background:#fffaf5e8;backdrop-filter:blur(14px);
  border-bottom:1px solid #e6d5c7;display:flex;align-items:center;gap:18px;padding:12px 34px;box-shadow:0 10px 30px #9b7b5c18
}
.proBrand{display:flex;align-items:center;gap:12px;border:0;background:transparent;min-width:230px}
.proBrand img{width:58px;height:42px;object-fit:contain}
.proBrand span{display:flex;flex-direction:column;text-align:left}
.proBrand b{font-size:1.2rem}
.proBrand small{color:var(--brown)}
.proNav nav{display:flex;gap:24px;align-items:center;flex:1;overflow:auto;white-space:nowrap}
.proNav nav button{border:0;background:transparent;color:var(--ink);font-weight:600}
.proNav nav button:hover{color:var(--taupe)}
.proCv,.cvBtn{display:inline-flex;align-items:center;gap:8px;border-radius:999px;text-decoration:none;font-weight:700;white-space:nowrap}
.proCv{background:linear-gradient(135deg,#b37b57,#8b5d45);color:#fff;padding:13px 20px;box-shadow:0 10px 20px #8b5d4530}
.langSelect{border:1px solid #e0cbb8;border-radius:999px;background:#fffaf4;padding:10px 14px;font-weight:700}
.proHero{position:relative;max-width:1500px;margin:auto;padding:70px 42px 28px;display:grid;grid-template-columns:1.05fr 1.25fr .78fr;gap:28px;align-items:center}
.proHero::before{content:"";position:absolute;inset:0;pointer-events:none;background:radial-gradient(circle at 70% 25%,#f0d9c5 0 19%,transparent 20%),radial-gradient(circle at 8% 75%,#f1dfcd 0 14%,transparent 15%)}
.proIntro,.proPhotoArea,.proValues,.proCards,.proAccessBar,.proStarZone{position:relative;z-index:1}
.eyebrow{text-transform:uppercase;letter-spacing:.14em;color:var(--brown);font-weight:800}
.proIntro h1{font-size:clamp(2.1rem,4.2vw,4.6rem);line-height:1.06;margin:12px 0;color:var(--ink)}
.proIntro h1::first-letter{color:var(--taupe)}
.proIntro p{font-size:1.08rem;line-height:1.75;max-width:620px}
.proActions{display:flex;gap:14px;flex-wrap:wrap;margin-top:24px}
.proActions button{border:1px solid #d3baa6;background:#fff;border-radius:12px;padding:13px 20px;font-weight:700;color:var(--brown)}
.proActions button:first-child{background:var(--taupe);color:#fff}
.proPhotoArea{min-height:470px;display:flex;align-items:center;justify-content:center}
.proPhoto{width:min(380px,80%);height:480px;object-fit:cover;object-position:center top;border-radius:42% 42% 22px 22px;box-shadow:0 30px 60px #6b4a3524;border:10px solid #fff7ef}
.screenCard{position:absolute;right:0;top:52px;width:300px;background:#fffaf4;border:1px solid #e5d4c6;border-radius:18px;padding:22px;box-shadow:0 20px 45px #8b5d4520}
.screenCard h3{margin:0 0 8px;color:var(--petrol);letter-spacing:.08em}
.screenCard p{margin:0 0 14px}
.screenIcons{display:grid;grid-template-columns:1fr 1fr;gap:10px;font-size:.82rem}
.screenIcons span{display:flex;gap:6px;align-items:center}
.proValues{display:grid;gap:16px}
.proValues div{background:#fffaf4;border:1px solid #e5d4c6;border-radius:18px;padding:18px;display:grid;grid-template-columns:36px 1fr;gap:8px;box-shadow:0 18px 35px #8b5d4518}
.proValues svg{grid-row:span 2;color:#fff;background:var(--petrol);border-radius:50%;padding:9px;width:36px;height:36px}
.proValues small{color:#6b5b50}
.proCards{grid-column:1 / 4;display:grid;grid-template-columns:repeat(5,1fr);gap:16px;margin-top:20px}
.proCards button{min-height:180px;background:#fffdfa;border:1px solid #e3d3c8;border-radius:18px;padding:20px;text-align:left;color:var(--ink);box-shadow:0 18px 40px #8b5d4514;display:flex;flex-direction:column;gap:10px}
.proCards svg{color:#fff;background:var(--petrol);border-radius:50%;padding:10px;width:42px;height:42px}
.proCards b{font-size:1.08rem}
.proCards span{line-height:1.55;color:#3c454b}
.proAccessBar{grid-column:1/4;background:#fffdfa;border:1px solid #e3d3c8;border-radius:18px;padding:18px 22px;display:grid;grid-template-columns:1.1fr repeat(5,1fr);gap:14px;align-items:center;box-shadow:0 18px 40px #8b5d4514}
.proAccessBar span{display:flex;gap:8px;align-items:center}
.proStarZone{grid-column:1/4;display:flex;justify-content:flex-end;padding:4px 24px 0}

/* étoile non flottante, plus petite, texte dedans */
.starPortal{
  position:relative;border:0;background:transparent;width:190px;height:190px;display:grid;place-items:center;color:#8b5d45;
  filter:drop-shadow(0 0 12px #f4c36d);animation:starGlow 4s ease-in-out infinite
}
.starPortal svg{position:absolute;width:100%;height:100%;color:#fff7e7;stroke:#d09054;stroke-width:18;filter:drop-shadow(0 0 10px #f7c36b)}
.starPortal span{position:relative;z-index:2;max-width:125px;font-weight:800;font-size:.9rem;line-height:1.25;text-align:center;color:#7b4c34}
.starPortal.personal span{color:#fff}
.starPortal.personal svg{color:#2b103e;stroke:#ff8ae6}
@keyframes starGlow{0%,100%{transform:scale(1);filter:drop-shadow(0 0 8px #e2a65c)}50%{transform:scale(1.045);filter:drop-shadow(0 0 24px #f2bf66)}}

/* -------- V1 personnelle conservée -------- */
.site{background:#02040d;color:white;min-height:100vh}
.navBar{position:sticky;top:0;z-index:50;min-height:74px;background:#050713f7;border-bottom:1px solid #25152f;display:flex;align-items:center;gap:22px;padding:10px 24px}
.logoBtn{border:0;background:transparent;padding:0}
.logoBtn img{width:96px;height:46px;object-fit:contain;background:white}
.navBar nav{display:flex;gap:28px;align-items:center;flex:1;overflow:auto;white-space:nowrap}
.navBar nav button{border:0;background:transparent}
.cvBtn{background:linear-gradient(90deg,var(--pink),var(--purple));padding:12px 20px}
.hero{position:relative;min-height:min(640px,62vw);background:linear-gradient(90deg,#02040d22,#02040d00),url("/assets/fond-personnage-ville-chopper.png") center center / cover no-repeat;overflow:hidden}
.thoughtTitle{position:absolute;top:5.6%;left:52.5%;transform:translateX(-50%);width:36%;text-align:center;font-family:"Brush Script MT","Segoe Script",cursive;font-size:clamp(1.65rem,3.1vw,3.15rem);color:#ffc1f1;text-shadow:0 0 14px #ff55cd;z-index:3;pointer-events:none}
.thoughtBubble{position:absolute;top:21.5%;left:52.7%;transform:translateX(-50%);width:25%;min-height:15%;border:0;background:transparent;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;color:#ffb0ef;text-shadow:0 0 8px #ff55cd;font-weight:800;font-size:clamp(.58rem,.98vw,1.05rem);line-height:1.24;padding:0;z-index:4;pointer-events:none}
.thoughtBubble p{margin:.08rem 0}
.personalStarZone{position:absolute;right:36px;bottom:28px;z-index:8}
.personalStarZone .starPortal{width:160px;height:160px}

/* accessibilité */
.accessWrap{position:relative;display:inline-block}
.accessWrap.floating{position:fixed;right:22px;top:130px;z-index:80}
.accessRound,.accessFloating{width:54px;height:54px;border-radius:50%;border:2px solid #d4b8a2;background:#fffaf4;color:var(--petrol);display:grid;place-items:center;font-size:1.35rem;box-shadow:0 10px 24px #8b5d4524}
.accessRound.compact{width:46px;height:46px}
.accessFloating{position:fixed;right:22px;top:130px;border-color:#ff8be6;background:linear-gradient(135deg,var(--purple),var(--pink));color:white;font-size:2rem;z-index:80}
.accessPanel{position:absolute;right:0;top:62px;width:310px;background:linear-gradient(180deg,#fffdfa,#f7eee5);color:var(--ink);border:1px solid #e0cdbf;border-radius:18px;padding:18px;z-index:90;box-shadow:0 20px 60px #0003}
.site .accessPanel{position:fixed;right:22px;top:205px;background:linear-gradient(180deg,#0b1024f5,#050817f5);color:#fff;border:1px solid #5b4b77}
.accessPanel h2{color:var(--brown);margin-top:0}
.site .accessPanel h2{color:var(--pink)}
.accessPanel button,.accessPanel a{width:100%;display:flex;align-items:center;gap:.8em;padding:.85em;margin:.45em 0;border-radius:12px;border:1px solid #d8c7ba;background:#fff;text-decoration:none;color:inherit}
.site .accessPanel button,.site .accessPanel a{border:1px solid #273250;background:#081329}
.accessPanel svg{color:var(--petrol)}
.site .accessPanel svg{color:var(--cyan)}
.accessPanel small{display:block;font-size:.75rem;color:#74675e}
.site .accessPanel small{color:#d7cbe6}

/* langues */
.poly{display:flex;gap:18px;align-items:center;justify-content:center;flex-wrap:wrap;padding:20px 16px;background:#050713;border-bottom:1px solid #25152f;color:#fff}
.proSite .poly{background:#fffaf4;color:var(--ink);border-top:1px solid #eadbd0;border-bottom:1px solid #eadbd0}
.poly button{border:0;background:transparent;text-decoration:underline;font-weight:700}
.notions{width:100%;text-align:center;color:#d7cbe6;font-size:.95rem}
.proSite .notions{color:#6f6258}

/* slides */
.overlay{position:fixed;inset:0;background:#0009;z-index:100;display:flex;justify-content:flex-end}
.slide{width:min(720px,95vw);height:100%;overflow:auto;background:#080b1a;color:#fff;border-left:2px solid var(--pink);padding:30px;box-shadow:-20px 0 60px #000}
.proSlide{background:#fffaf5;color:var(--ink);border-left:2px solid var(--taupe)}
.close{float:right;background:#1a0e28;color:#fff;border:1px solid var(--pink);border-radius:50%;width:40px;height:40px;display:grid;place-items:center}
.proSlide .close{background:#fff;border-color:#d6bca9;color:var(--ink)}
.readSlide{background:#081329;border:1px solid #273250;border-radius:12px;padding:10px 14px;margin-bottom:14px;color:var(--cyan)}
.proSlide .readSlide{background:#fff;border-color:#d6bca9;color:var(--petrol)}
.slide h1,.slide h2,.slide h3{color:var(--pink)}
.proSlide h1,.proSlide h2,.proSlide h3{color:var(--brown)}
.photo{width:100%;height:auto;max-height:none;object-fit:contain;border-radius:16px;border:1px solid var(--line);background:#f6eef2}
.grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px}
.item,.line{display:flex;gap:12px;align-items:center;background:#081329;border:1px solid #273250;border-radius:12px;padding:14px;margin:10px 0;text-decoration:none}
.proSlide .item,.proSlide .line{background:#fff;border-color:#e2d2c6}
.aeshImageCard{font-size:3rem;text-align:center;background:linear-gradient(135deg,#fff,#f1dfcf);color:var(--petrol);border-radius:18px;padding:34px;display:flex;justify-content:center;gap:28px}
.vote{display:block;margin:12px 0}
.mainBtn,.ghostBtn{border:0;border-radius:12px;padding:12px 20px;margin:10px 10px 10px 0;background:linear-gradient(90deg,var(--pink),var(--purple));color:#fff}
.ghostBtn{background:#090817;border:1px solid var(--pink)}
.proSlide .ghostBtn{background:#fff;color:var(--brown);border-color:#d6bca9}
.results p{display:flex;justify-content:space-between;border-bottom:1px solid #273250;padding:10px}
.coming{text-align:center}.coming svg{font-size:4rem;color:var(--pink)}
[dir="rtl"] .overlay{justify-content:flex-start}
[dir="rtl"] .slide{border-left:0;border-right:2px solid var(--pink)}

@media(max-width:1000px){
  .proNav{flex-wrap:wrap;padding:12px 16px}
  .proNav nav{order:3;width:100%;font-size:.9rem}
  .proHero{grid-template-columns:1fr;padding:40px 16px}
  .proCards,.proAccessBar,.proStarZone{grid-column:auto}
  .proCards{grid-template-columns:1fr}
  .proAccessBar{grid-template-columns:1fr 1fr}
  .proPhotoArea{min-height:430px}
  .screenCard{right:12px;top:280px;width:260px}
  .proValues{grid-template-columns:1fr 1fr}
  .proStarZone{justify-content:center}
}
@media(max-width:900px){
  .navBar{flex-wrap:wrap;padding:10px 14px}
  .navBar nav{order:3;width:100%;font-size:.9rem}
  .hero{min-height:640px;background-size:auto 640px;background-position:center top}
  .thoughtTitle{top:7%;left:54%;width:300px;font-size:1.55rem}
  .thoughtBubble{top:19%;left:54%;width:230px;min-height:135px;font-size:.66rem;line-height:1.2;padding:0}
  .accessFloating{top:120px;right:14px;width:56px;height:56px;font-size:1.7rem}
  .site .accessPanel{top:184px;right:10px;width:285px;padding:14px}
  .grid{grid-template-columns:1fr}
  .personalStarZone{right:10px;bottom:10px}
  .personalStarZone .starPortal{width:135px;height:135px}
  .starPortal{width:155px;height:155px}
  .starPortal span{font-size:.78rem;max-width:105px}
}


